{
  "expo": {
    "name": "eliteboards-mobile",
    "slug": "eliteboards-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "eliteboards",
    "icon": "./assets/logo.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/logo.png",
      "resizeMode": "contain",
      "backgroundColor": "#020617"
    },
    "updates": {
      "fallbackToCacheTimeout": 0,
      "url": "https://u.expo.dev/83fb6e86-1c2f-49cb-aaf7-d3193421ba54"
    },
    "extra": {
      "API_URL": "https://leaderboard-backend-3pek.onrender.com",
      "eas": {
        "projectId": "83fb6e86-1c2f-49cb-aaf7-d3193421ba54"
      }
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.parasmanikhunte.eliteboards",
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#020617",
        "foregroundImage": "./assets/logo.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/logo.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.parasmanikhunte.eliteboards"
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "owner": "parasmani",
    "plugins": [
      "expo-router",
      "expo-secure-store",
      "expo-web-browser"
    ],
    "runtimeVersion": {
      "policy": "appVersion"
    }
  }
}
